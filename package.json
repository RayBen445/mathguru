{
  "name": "mathguru",
  "version": "1.2.0",
  "description": "MathGuru ecosystem-grade developer terminal toolkit. Powered by Kontyra.",
  "main": "index.js",
  "types": "types/index.d.ts",
  "bin": {
    "mathguru": "./bin/mathguru.js",
    "mg": "./bin/mathguru.js"
  },
  "scripts": {
    "test": "jest",
    "test:legacy": "node test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "release:patch": "npm version patch && npm run changelog",
    "release:minor": "npm version minor && npm run changelog",
    "release:major": "npm version major && npm run changelog",
    "validate:package": "node scripts/validate-package.js",
    "validate:version-tag": "node scripts/verify-version-tag.js",
    "typecheck": "tsc --project tsconfig.types.json",
    "prepublish:check": "npm run lint && npm run format:check && npm test && npm run test:legacy && npm run typecheck && npm run validate:package"
  },
  "keywords": [
    "math",
    "calculator",
    "arithmetic",
    "scientific",
    "economics",
    "finance",
    "cli",
    "shell",
    "utility",
    "kontyra",
    "developer-tooling",
    "terminal"
  ],
  "author": "RayBen445",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RayBen445/mathguru.git"
  },
  "bugs": {
    "url": "https://github.com/RayBen445/mathguru/issues"
  },
  "homepage": "https://github.com/RayBen445/mathguru#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "figlet": "^1.11.0",
    "inquirer": "^9.3.8",
    "ora": "^5.4.1",
    "update-notifier": "^6.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "conventional-changelog-cli": "^5.0.0",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "kontyra": {
    "poweredBy": "Powered by Kontyra",
    "aiReady": true,
    "aiImplemented": false
  },
  "files": [
    "bin/",
    "src/",
    "types/",
    "index.js",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "RELEASE.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md"
  ]
}
